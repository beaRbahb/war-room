{
  "rules": {
    "rooms": {
      "$roomCode": {
        ".read": "auth != null",
        ".write": "auth != null",
        "config": {
          ".validate": "newData.hasChildren(['roomCode', 'commissionerId', 'commissionerName', 'status', 'createdAt'])"
        },
        "users": {
          "$userId": {
            ".validate": "newData.hasChildren(['name', 'id', 'joinedAt', 'isCommissioner', 'isActive'])"
          }
        },
        "brackets": {
          "$userName": {
            ".validate": "newData.hasChildren(['userName', 'picks'])"
          }
        },
        "live": {
          ".validate": "newData.hasChildren(['currentPick', 'windowOpen', 'teamOnClock'])"
        },
        "live_guesses": {
          "$pickKey": {
            "$userName": {
              ".validate": "newData.isString() && newData.val().length <= 100"
            }
          }
        },
        "results": {
          "$pickKey": {
            ".validate": "newData.hasChildren(['pick', 'playerName', 'teamAbbrev', 'confirmedAt', 'isBearsPick'])"
          }
        },
        "reactions": {
          "$pickKey": {
            "$userName": {
              ".validate": "newData.hasChildren(['reaction'])"
            }
          }
        },
        "roasts": {
          "$pickKey": {
            "$userName": {
              ".validate": "newData.hasChildren(['text', 'submittedAt']) && newData.child('text').isString() && newData.child('text').val().length <= 120"
            }
          }
        },
        "scores": {
          "$userName": {
            ".validate": "newData.hasChildren(['bracketScore', 'liveScore'])"
          }
        }
      }
    },
    ".read": false,
    ".write": false
  }
}
